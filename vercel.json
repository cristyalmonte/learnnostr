{
  "framework": null,
  "buildCommand": "chmod +x build.sh && ./build.sh",
  "outputDirectory": "site",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Language",
          "value": "en"
        }
      ]
    },
    {
      "source": "/es/(.*)",
      "headers": [
        {
          "key": "Content-Language",
          "value": "es"
        }
      ]
    }
  ]
} 